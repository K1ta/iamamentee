APP_LISTEN=:8080

APP_POSTGRES_PG0_HOST=postgres-0.postgres.product-management-infra:5432
APP_POSTGRES_PG0_DATABASE=product-management
APP_POSTGRES_PG0_USER=admin
APP_POSTGRES_PG0_PASSWORD=password
APP_POSTGRES_PG0_SSL_MODE=disable

APP_POSTGRES_PG1_HOST=postgres-1.postgres.product-management-infra:5432
APP_POSTGRES_PG1_DATABASE=product-management
APP_POSTGRES_PG1_USER=admin
APP_POSTGRES_PG1_PASSWORD=password
APP_POSTGRES_PG1_SSL_MODE=disable

APP_SHARDS=products-0:PG0,products-1:PG1
#APP_PREV_SHARDS=products-0:postgres-0

APP_MAIN_DB=PG0

APP_KAFKA_BROKERS=kafka.kafka-common:9092
APP_KAFKA_WRITER_BATCH_SIZE=100

APP_OUTBOX_PAUSE_WHEN_NO_WORK=1s
APP_OUTBOX_MAX_ATTEMPTS=10
APP_OUTBOX_PROCESSOR_BATCH_SIZE=100
# у writer кафки 10 попыток, с учетом встроенного backoff максимум занимают до 10 секунд
APP_OUTBOX_PROCESSOR_ATTEMPT_DURATION_SECONDS=10

APP_RESERVATION_INTERVAL_SEC=5
APP_RESERVATION_MAX_ATTEMPTS=10
APP_RESERVATION_PAUSE_WHEN_NO_WORK=1s
APP_PAYMENT_INTERVAL_SEC=5
APP_PAYMENT_PAUSE_WHEN_NO_WORK=1s

APP_PAYMENTS_URL=http://payments.payments